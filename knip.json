{
  "ignoreDependencies": [
    "graphql",
    "@nitra/cspell-dict",
    "@nitra/stylelint-config",
    "globals",
    "@stryker-mutator/core",
    "@7n/rules-ci-github",
    "@7n/rules-ci-azure",
    "@7n/rules-lang-python",
    "@7n/rules-lang-rust",
    "@7n/rules-lang-js"
  ],
  "ignoreBinaries": [
    "cspell",
    "oxfmt",
    "stylelint",
    "trufflehog",
    "pi",
    "claude",
    "cursor-agent",
    "fix-t0",
    "_fix-check"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "npm/rules/**/js/applies.mjs": [
      "exports"
    ],
    "npm/rules/k8s/js/manifests.mjs": [
      "exports"
    ],
    "npm/scripts/lib/gha-workflow.mjs": [
      "exports"
    ]
  },
  "workspaces": {
    ".": {
      "entry": [
        "eslint.config.{js,mjs}",
        ".pi/extensions/**/*.ts"
      ]
    },
    "npm": {
      "entry": [
        "bin/n-rules.js",
        "bin/rename-yaml-extensions.mjs",
        "rules/*/lib/*.mjs",
        "rules/*/*/main.mjs",
        "rules/*/*/fix-*.mjs",
        "rules/*/*/coverage.mjs",
        "scripts/auto-*.mjs",
        "scripts/build-*.mjs",
        "scripts/claude-stop-hook.mjs",
        "scripts/update-blue-oak.mjs",
        "scripts/ensure-n-rules-dev-dependencies.mjs",
        "scripts/rename-yaml-extensions.mjs",
        "scripts/sync-*.mjs",
        "scripts/upgrade-n-rules-and-install.mjs",
        "scripts/lib/run-rule-cli.mjs",
        "scripts/lib/run-rule.mjs",
        "scripts/lib/run-standard-rule.mjs",
        "scripts/lib/lint-surface/tier-sampling-bench.mjs",
        "scripts/lib/lint-surface/tier-sampling-experiment.mjs",
        "rules/**/*.test.mjs",
        "scripts/**/*.test.mjs",
        "tests/**/*.test.mjs",
        "scripts/tests/fixtures/**/*.mjs",
        "rules/test/js/data/stryker_config/stryker.config.baseline.mjs",
        "stryker.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ],
      "ignoreDependencies": [
        "@anthropic-ai/claude-code",
        "@anthropic-ai/sdk",
        "@7n/mt",
        "github-actionlint",
        "v8r",
        "ajv",
        "jscpd"
      ]
    },
    "demo": {
      "ignoreDependencies": [
        "vite-plugin-vue-layouts-next",
        "lightningcss"
      ],
      "entry": [
        "stryker.config.mjs"
      ]
    },
    "llm-lib": {
      "entry": [
        "lib/*.mjs",
        "tests/**/*.test.mjs",
        "stryker.config.mjs"
      ],
      "project": [
        "**/*.mjs"
      ],
      "ignoreDependencies": [
        "@earendil-works/pi-coding-agent",
        "@earendil-works/pi-ai"
      ]
    },
    "plugins/ci-github": {
      "entry": [
        "rules/*/lib/*.mjs",
        "rules/*/*/main.mjs",
        "rules/*/*/fix-*.mjs",
        "rules/**/*.test.mjs",
        "stryker.config.mjs",
        "vitest.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ]
    },
    "plugins/ci-azure": {
      "entry": [
        "rules/*/lib/*.mjs",
        "rules/*/*/main.mjs",
        "rules/*/*/fix-*.mjs",
        "rules/**/*.test.mjs",
        "stryker.config.mjs",
        "vitest.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ]
    },
    "plugins/lang-python": {
      "entry": [
        "rules/*/lib/*.mjs",
        "rules/*/*/main.mjs",
        "rules/*/*/fix-*.mjs",
        "rules/**/*.test.mjs",
        "taze/provider.mjs",
        "taze/**/*.test.mjs",
        "stryker.config.mjs",
        "vitest.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ]
    },
    "plugins/lang-rust": {
      "entry": [
        "doc-files/extractors.mjs",
        "rules/*/lib/*.mjs",
        "rules/*/*/main.mjs",
        "rules/*/*/fix-*.mjs",
        "rules/**/*.test.mjs",
        "taze/provider.mjs",
        "taze/**/*.test.mjs",
        "stryker.config.mjs",
        "vitest.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ]
    },
    "plugins/lang-js": {
      "entry": [
        "taze/provider.mjs",
        "taze/**/*.test.mjs",
        "stryker.config.mjs",
        "vitest.config.mjs"
      ],
      "project": [
        "**/*.{js,mjs}"
      ]
    }
  }
}
