{
  "name": "@7n/rules-ci-github",
  "version": "1.9.4",
  "description": "Плагін @7n/rules: канон GitHub Actions (.github/workflows) — обов'язкові workflow, zizmor, VS Code",
  "keywords": [
    "github-actions",
    "ci",
    "lint",
    "n-rules-plugin"
  ],
  "homepage": "https://github.com/nitra/7n-rules#readme",
  "bugs": {
    "url": "https://github.com/nitra/7n-rules/issues"
  },
  "license": "ISC",
  "author": "v@nitra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitra/7n-rules.git",
    "directory": "plugins/ci-github"
  },
  "type": "module",
  "files": [
    "rules",
    "CHANGELOG.md",
    "!**/*.test.mjs",
    "!**/*_test.rego",
    "!**/fixtures/**",
    "!**/tests/**"
  ],
  "n-rules": {
    "capabilities": [
      "ci:github"
    ],
    "contributes": {
      "rules": true
    }
  },
  "peerDependencies": {
    "@7n/rules": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
