{
  "name": "@7n/rules-lang-rust",
  "version": "0.7.1",
  "description": "Плагін @7n/rules: Rust/Cargo-екосистема — taze-провайдер (Cargo.toml, cargo-edit)",
  "keywords": [
    "rust",
    "cargo",
    "taze",
    "n-rules-plugin"
  ],
  "homepage": "https://github.com/nitra/7n-rules#readme",
  "bugs": {
    "url": "https://github.com/nitra/7n-rules/issues"
  },
  "license": "ISC",
  "author": "v@nitra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitra/7n-rules.git",
    "directory": "plugins/lang-rust"
  },
  "type": "module",
  "files": [
    "rules",
    "doc-files",
    "taze",
    "skills",
    "CHANGELOG.md",
    "!**/*.test.mjs",
    "!**/*_test.rego",
    "!**/fixtures/**",
    "!**/tests/**"
  ],
  "n-rules": {
    "capabilities": [
      "lang:rust"
    ],
    "contributes": {
      "rules": true,
      "handlers": {
        "taze": "./taze/provider.mjs",
        "doc-files": "./doc-files/extractors.mjs"
      },
      "docFiles": {
        "extensions": {
          ".rs": "Rust Module"
        }
      }
    }
  },
  "dependencies": {
    "globby": "^16.0.0",
    "smol-toml": "^1.7.0"
  },
  "peerDependencies": {
    "@7n/rules": ">=1.15.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  }
}
