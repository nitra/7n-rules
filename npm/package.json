{
  "name": "@nitra/cursor",
  "version": "14.25.1",
  "description": "CLI для завантаження cursor-правил (префікс n-) у локальний репозиторій",
  "keywords": [
    "cli",
    "cursor",
    "cursor-rules",
    "mdc",
    "n",
    "pi-package"
  ],
  "homepage": "https://github.com/n/cursor#readme",
  "bugs": {
    "url": "https://github.com/n/cursor/issues"
  },
  "license": "ISC",
  "author": "v@nitra.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n/cursor.git"
  },
  "bin": {
    "n-cursor": "bin/n-cursor.js"
  },
  "files": [
    "docs",
    "types",
    "rules",
    "bin",
    "github-actions",
    "schemas",
    "scripts",
    "skills",
    ".claude-template",
    ".pi-template",
    "AGENTS.template.md",
    "CHANGELOG.md",
    "!**/*.test.mjs",
    "!**/*_test.rego",
    "!**/test-helpers.mjs",
    "!**/fixtures/**",
    "!**/__fixtures__/**"
  ],
  "type": "module",
  "types": "./types/bin/n-cursor.d.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "bun ./bin/n-cursor.js",
    "rename-yaml-extensions": "bun ./bin/n-cursor.js rename-yaml-extensions"
  },
  "dependencies": {
    "@7n/mt": "^0.5.1",
    "@7n/llm-lib": "^2.0.0",
    "ajv": "^8.20.0",
    "cli-progress": "^3.12.0",
    "eslint": "^10.4.1",
    "github-actionlint": "^1.7.12",
    "globby": "^16.0.0",
    "ignore": "^7.0.5",
    "jscpd": "^5.0.11",
    "knip": "^6.22.0",
    "markdownlint-cli2": "^0.22.1",
    "oxc-parser": "^0.137.0",
    "oxlint": "^1.68.0",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.7.0",
    "v8r": "^6.1.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@earendil-works/pi-ai": "0.80.2",
    "@earendil-works/pi-coding-agent": "0.80.2"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=25"
  },
  "pi": {
    "skills": "skills",
    "extensions": ".pi-template/extensions"
  }
}
