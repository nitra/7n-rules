{
  "$schema": "https://unpkg.com/@7n/rules/schemas/concern.json",
  "fixability": "config",
  "policy": {
    "files": {
      "single": ".github/workflows/lint-rust.yml",
      "required": true
    },
    "missingMessage": ".github/workflows/lint-rust.yml не існує — створи з канонічним вмістом (rust.mdc)"
  },
  "requires": {
    "capability": "ci:github"
  }
}
