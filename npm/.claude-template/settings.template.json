{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx *)",
      "Bash(npx --no @nitra/cursor *)",
      "Bash(npx @nitra/cursor *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor post-tool-use-fix",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor lint-doc-files --hook",
            "timeout": 120
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor lint-doc-files --git",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
