{
  "permissions": {
    "allow": [
      "Bash(bun *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx *)",
      "Bash(npx --no @nitra/cursor *)",
      "Bash(npx @nitra/cursor *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor hook --post-tool-use",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
