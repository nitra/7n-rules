{
  "version": "0.2",
  "language": "en,uk,ru-ru,nitra",
  "ignorePaths": [
    "**/node_modules/**",
    "**/vscode-extension/**",
    "**/.git/**",
    ".vscode",
    ".zed",
    "report",
    "**/reports/stryker/**",
    "*.svg",
    "**/k8s/**/*.yaml",
    "docs/adr/**",
    "**/adr/**",
    "docs/superpowers/**",
    "**/*.html",
    "**/dist/**"
  ],
  "import": ["@nitra/cspell-dict/cspell-ext.json"],
  "words": [
    "toplevel",
    "worktree",
    "worktrees",
    "скіл",
    "скіли",
    "скілом",
    "дубляту",
    "інстанс",
    "промпт",
    "диспатч",
    "диспатчиться",
    "хардкодить",
    "комітить",
    "комітити",
    "пропагацію"
  ]
}
