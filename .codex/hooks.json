{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor hook --post-tool-use",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx --no @nitra/cursor hook --stop",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
