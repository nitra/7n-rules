    "./anchored-edit": "./lib/anchored-edit.mjs",
    "./web-tools": "./lib/web-tools.mjs",
    "./model-tiers": "./lib/model-tiers.mjs",
    "./acp": "./lib/acp.mjs",
    "./chain": "./lib/chain.mjs",
    "./chains-report": "./lib/chains-report.mjs",
    "./one-shot": "./lib/one-shot.mjs",
    "./agent-fix": "./lib/agent-fix.mjs",
    "./agent-skill": "./lib/agent-skill.mjs",
    "./write-guard": "./lib/write-guard.mjs",
    "./trace": "./lib/trace.mjs",
    "./telemetry-store": "./lib/telemetry-store.mjs",
    "./with-timeout": "./lib/with-timeout.mjs",
    "./prompt-budget": "./lib/prompt-budget.mjs",
    "./body-capture": "./lib/body-capture.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@7n/llm-lib-darwin-arm64": "2.7.6",
    "@7n/llm-lib-linux-x64": "2.7.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "~0.80.10",
