{
  "name": "mono",
  "version": "1.0.0",
  "private": true,
  "license": "ISC",
  "workspaces": [
    "npm",
    "demo",
    "llm-lib",
    "plugins/ci-github",
    "plugins/ci-azure",
    "plugins/lang-python",
    "plugins/lang-rust",
    "plugins/lang-js"
  ],
  "type": "module",
  "scripts": {
    "start": "bun ./npm/bin/n-rules.js",
    "test": "bun run --bun vitest run",
    "coverage": "npx @7n/rules lint test --no-fix"
  },
  "devDependencies": {
    "@nitra/cspell-dict": "^2.2.2",
    "@nitra/eslint-config": "^3.10.3",
    "@nitra/stylelint-config": "^1.4.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.9",
    "vitest": "^4.1.9",
    "@7n/rules": "workspace:*",
    "@7n/rules-ci-github": "workspace:*",
    "@7n/rules-ci-azure": "workspace:*",
    "@7n/rules-lang-python": "workspace:*",
    "@7n/rules-lang-rust": "workspace:*",
    "@7n/rules-lang-js": "workspace:*"
  },
  "stylelint": {
    "extends": "@nitra/stylelint-config"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "knip": {
    "ignore": [
      "demo/stryker-vue-macros-ignorer.mjs",
      "npm/rules/test/js/data/stryker_config/stryker.config.vue.baseline.mjs",
      "npm/skills/fix/js/llm-worker.mjs"
    ]
  }
}
