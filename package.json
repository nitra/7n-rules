{
  "name": "mono",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "npm",
    "demo"
  ],
  "type": "module",
  "scripts": {
    "start": "bun ./npm/bin/n-cursor.js",
    "test": "vitest run",
    "lint": "bun run lint-ga && bun run lint-js && bun run lint-python && bun run lint-rego && bun run lint-security && bun run lint-style && bun run lint-text && oxfmt .",
    "lint-ga": "n-cursor lint-ga",
    "lint-js": "bunx oxlint --fix && bunx eslint --fix . && bunx jscpd . && bunx knip --no-config-hints",
    "lint-python": "bun ./node_modules/@nitra/cursor/rules/python/lint/lint.mjs",
    "lint-rego": "n-cursor lint-rego",
    "lint-security": "trufflehog filesystem . --no-update --exclude-paths .trufflehog-exclude --results=verified,unknown --fail",
    "lint-style": "npx stylelint '**/*.{css,scss,vue}' --fix",
    "lint-text": "n-cursor lint-text",
    "oxfmt": "oxfmt .",
    "coverage": "n-cursor coverage",
    "benchmark": "bun benchmarks/runner-comparison/run.mjs"
  },
  "devDependencies": {
    "@nitra/cspell-dict": "^2.2.0",
    "@nitra/cursor": "^4.0.0",
    "@nitra/eslint-config": "^3.10.1",
    "@nitra/stylelint-config": "^1.4.0",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.7",
    "vitest": "^4.1.7"
  },
  "stylelint": {
    "extends": "@nitra/stylelint-config"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "knip": {
    "ignore": [
      "demo/stryker-vue-macros-ignorer.mjs",
      "npm/rules/test/js/data/stryker_config/stryker.config.vue.baseline.mjs"
    ]
  }
}
